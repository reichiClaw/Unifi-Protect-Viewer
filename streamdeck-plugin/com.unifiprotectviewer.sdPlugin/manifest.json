{
	"SDKVersion": 2,
	"UUID": "com.unifiprotectviewer",
	"Author": "UniFi Protect Viewer",
	"Name": "UniFi Protect Viewer",
	"Description": "Switch grid views, pop cameras fullscreen, and control PTZ in the UniFi Protect Viewer macOS app.",
	"Version": "1.2.0.0",
	"URL": "https://github.com/reichiClaw/Unifi-Protect-Viewer",
	"Icon": "icons/plugin",
	"Category": "UniFi Protect Viewer",
	"CategoryIcon": "icons/category",
	"CodePath": "plugin/index.html",
	"PropertyInspectorPath": "pi/inspector.html",
	"OS": [
		{
			"Platform": "mac",
			"MinimumVersion": "10.15"
		}
	],
	"Software": {
		"MinimumVersion": "6.4"
	},
	"Actions": [
		{
			"UUID": "com.unifiprotectviewer.switchview",
			"Name": "Switch View",
			"Tooltip": "Switch the viewer to a specific grid view.",
			"Icon": "icons/switchView",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/switchViewKey",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.nextview",
			"Name": "Next View",
			"Tooltip": "Switch to the next grid view.",
			"Icon": "icons/nextView",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/nextViewKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.prevview",
			"Name": "Previous View",
			"Tooltip": "Switch to the previous grid view.",
			"Icon": "icons/prevView",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/prevViewKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.fullscreen",
			"Name": "Camera Fullscreen",
			"Tooltip": "Show a specific camera fullscreen (toggles back to the grid).",
			"Icon": "icons/fullscreen",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/fullscreenKey",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.exitfullscreen",
			"Name": "Exit Fullscreen",
			"Tooltip": "Return from fullscreen to the grid.",
			"Icon": "icons/exitFullscreen",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/exitFullscreenKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzpreset",
			"Name": "PTZ: Go to Preset",
			"Tooltip": "Move the fullscreen PTZ camera to a saved preset slot.",
			"Icon": "icons/ptz",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzKey",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzhome",
			"Name": "PTZ: Home",
			"Tooltip": "Move the fullscreen PTZ camera to its home position.",
			"Icon": "icons/ptzHome",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzHomeKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzpatrol",
			"Name": "PTZ: Start Patrol",
			"Tooltip": "Start a patrol (tour) on the fullscreen PTZ camera.",
			"Icon": "icons/ptzPatrol",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzPatrolKey",
					"TitleAlignment": "bottom",
					"FontSize": 12
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzstop",
			"Name": "PTZ: Stop Patrol",
			"Tooltip": "Stop the active patrol on the fullscreen PTZ camera.",
			"Icon": "icons/ptzStop",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzStopKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzup",
			"Name": "PTZ: Tilt Up",
			"Tooltip": "Hold to tilt the fullscreen PTZ camera up; release to stop.",
			"Icon": "icons/ptzUp",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzUpKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzdown",
			"Name": "PTZ: Tilt Down",
			"Tooltip": "Hold to tilt the fullscreen PTZ camera down; release to stop.",
			"Icon": "icons/ptzDown",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzDownKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzleft",
			"Name": "PTZ: Pan Left",
			"Tooltip": "Hold to pan the fullscreen PTZ camera left; release to stop.",
			"Icon": "icons/ptzLeft",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzLeftKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzright",
			"Name": "PTZ: Pan Right",
			"Tooltip": "Hold to pan the fullscreen PTZ camera right; release to stop.",
			"Icon": "icons/ptzRight",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzRightKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzzoomin",
			"Name": "PTZ: Zoom In",
			"Tooltip": "Hold to zoom the fullscreen PTZ camera in; release to stop.",
			"Icon": "icons/ptzZoomIn",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzZoomInKey",
					"TitleAlignment": "bottom"
				}
			]
		},
		{
			"UUID": "com.unifiprotectviewer.ptzzoomout",
			"Name": "PTZ: Zoom Out",
			"Tooltip": "Hold to zoom the fullscreen PTZ camera out; release to stop.",
			"Icon": "icons/ptzZoomOut",
			"Controllers": [
				"Keypad"
			],
			"PropertyInspectorPath": "pi/inspector.html",
			"States": [
				{
					"Image": "icons/ptzZoomOutKey",
					"TitleAlignment": "bottom"
				}
			]
		}
	]
}